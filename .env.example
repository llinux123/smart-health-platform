# ============================================================
# Smart Health Platform - 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据实际情况修改
#   cp .env.example .env
# ============================================================

# AI API Key（通义千问/阿里云模型服务）
AI_API_KEY=your-ai-api-key-here

# 智谱 AI API Key（多模态图片分析）
ZHIPU_API_KEY=your-zhipu-api-key-here

# JWT 密钥（可选，不设置则使用默认值）
# JWT_SECRET=your-jwt-secret-here

# 短信服务（mock=本地日志不发送，aliyun=阿里云SMS）
SMS_PROVIDER=mock

# 阿里云SMS凭证（sms.provider=aliyun 时必填）
# 需先在阿里云控制台完成：个人实名认证 → 创建AccessKey → 申请短信签名 → 创建验证码模板
SMS_ALIYUN_ACCESS_KEY_ID=
SMS_ALIYUN_ACCESS_KEY_SECRET=
SMS_ALIYUN_SIGN_NAME=
SMS_ALIYUN_TEMPLATE_CODE=
