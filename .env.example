# ============================================================
# Smart Health Platform - 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据实际情况修改
#   cp .env.example .env
#
# 本地开发（非Docker）时，application.yml 中的 localhost 默认值可用
# Docker Compose 部署时必须设置所有标有 [必需] 的变量
# ============================================================

# MySQL 数据库连接
DB_USERNAME=root
DB_PASSWORD=root123456

# RabbitMQ 消息队列
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123

# Elasticsearch 密码（xpack.security.enabled=true）
ES_PASSWORD=your-es-password-here

# JWT 密钥（[必需] 用于签名JWT令牌，请使用高强度随机字符串）
JWT_SECRET=your-jwt-secret-here

# AI API Key（通义千问/阿里云模型服务）
AI_API_KEY=your-ai-api-key-here

# 智谱 AI API Key（多模态图片分析）
ZHIPU_API_KEY=your-zhipu-api-key-here

# 短信服务（[必需] dypnsapi=阿里云号码认证, mock=本地日志不发送）
SMS_PROVIDER=mock

# 阿里云号码认证凭证（sms.provider=dypnsapi 时必填）
# 前往 https://dypnsapi.console.aliyun.com/ 开通号码认证服务
# SendSmsVerifyCode 使用系统预置模板，个人实名认证即可使用
SMS_DYPNSAPI_ACCESS_KEY_ID=
SMS_DYPNSAPI_ACCESS_KEY_SECRET=
SMS_DYPNSAPI_TEMPLATE_CODE=
# 以下为可选
SMS_DYPNSAPI_ENDPOINT=dypnsapi.aliyuncs.com
SMS_DYPNSAPI_SIGN_NAME=

# 邮箱服务（mock=本地日志, smtp=SMTP邮件发送）
EMAIL_PROVIDER=mock

# SMTP 配置（email.provider=smtp 时必填）
# 常用 SMTP 服务器：
#   QQ邮箱: smtp.qq.com 端口 465(SSL) / 587(TLS)
#   163邮箱: smtp.163.com 端口 465(SSL)
#   Gmail: smtp.gmail.com 端口 587(TLS)
#   企业微信: smtp.exmail.qq.com 端口 465(SSL)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
